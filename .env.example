# Copy this file to .env and fill in your values. Never commit .env.

# Required — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Target application under test
BASE_URL=https://the-internet.herokuapp.com
API_BASE_URL=https://jsonplaceholder.typicode.com

# Test credentials (used by network tests and login page tests)
TEST_USERNAME=tomsmith
TEST_EMAIL=test@example.com
TEST_PASSWORD=SuperSecretPassword!

# Allure output directory (default is correct for most setups)
ALLURE_RESULTS_DIR=reports/allure-results
